{
  "info": {
    "name": "NutriSync API Tests",
    "description": "Colección con auto-login y validaciones. Importa el environment 'tests/postman_environment.json' y asigna 'Nutritionist' al primer request de Auth para usar {{accessToken}} y 'Patient' al segundo para {{patientToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "noauth" },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Nutritionist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json.data.accessToken).to.be.a('string'));",
                  "pm.test('Has refreshToken', () => pm.expect(json.data.refreshToken).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "console.log('Nutritionist logged in:', json.data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] },
"body": { "mode": "raw", "raw": "{\n  \"email\": \"nutriologo@nutrisync.com\",\n  \"password\": \"nutrisync251243\"\n}" }
          }
        },
        {
          "name": "Login Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Role is patient', () => pm.expect(json.data.user.role).to.eql('patient'));",
                  "pm.collectionVariables.set('patientToken', json.data.accessToken);",
                  "if (json.data.user.patientProfileId) {",
                  "  pm.collectionVariables.set('patientId', json.data.user.patientProfileId);",
                  "}",
                  "console.log('Patient logged in:', json.data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"patient1@example.com\",\n  \"password\": \"Patient123!\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('accessToken')) {",
              "  console.log('No accessToken, login needed. Run Auth > Login Nutritionist first.');",
              "  return;",
              "}"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "Create Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Has patient data', () => {",
                  "  pm.expect(json.data.id).to.be.a('string');",
                  "  pm.expect(json.data.user.email).to.be.a('string');",
                  "  pm.collectionVariables.set('patientId', json.data.id);",
                  "  pm.collectionVariables.set('patientUserId', json.data.user.id);",
                  "  console.log('patientId:', json.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/v1/patients", "host": ["{{baseUrl}}"], "path": ["v1", "patients"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"patient1@example.com\",\n  \"password\": \"Patient123!\",\n  \"name\": \"Juan Perez\",\n  \"phone\": \"5551234567\",\n  \"birthDate\": \"1990-05-15\",\n  \"gender\": \"male\"\n}" }
          }
        },
        {
          "name": "List Patients",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('Is array', () => pm.expect(json.data).to.be.an('array'));", "console.log('Patients count:', json.data.length);"] } }
          ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": { "raw": "{{baseUrl}}/v1/patients", "host": ["{{baseUrl}}"], "path": ["v1", "patients"] } }
        },
        {
          "name": "Get Patient",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('Has name', () => pm.expect(json.data.user.name).to.be.a('string'));"] } }
          ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": { "raw": "{{baseUrl}}/v1/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["v1", "patients", "{{patientId}}"] } }
        },
        {
          "name": "Update Patient",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }
          ],
          "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["v1", "patients", "{{patientId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Juan Updated\",\n  \"phone\": \"5550000000\"\n}" } }
        }
      ]
    },
    {
      "name": "Clinical Records",
      "event": [
        { "listen": "prerequest", "script": { "exec": ["if (!pm.collectionVariables.get('accessToken')) { console.log('Run Auth > Login Nutritionist first'); }"] } }
      ],
      "item": [
        {
          "name": "Create Record",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.test('BMI calculated', () => { pm.expect(json.data.bmi).to.be.a('number'); pm.expect(json.data.riskLevel).to.be.a('string'); pm.collectionVariables.set('recordId', json.data.id); });"] } }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/clinical-records", "host": ["{{baseUrl}}"], "path": ["v1", "clinical-records"] }, "body": { "mode": "raw", "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"date\": \"2025-06-01\",\n  \"data\": { \"weightKg\": 75, \"heightCm\": 170, \"age\": 34, \"gender\": \"male\" }\n}" } }
        },
        {
          "name": "List by Patient",
          "event": [ { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('Is array', () => pm.expect(json.data).to.be.an('array'));"] } } ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": { "raw": "{{baseUrl}}/v1/clinical-records/patient/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["v1", "clinical-records", "patient", "{{patientId}}"] } }
        },
        {
          "name": "Get Record",
          "event": [ { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } } ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": { "raw": "{{baseUrl}}/v1/clinical-records/{{recordId}}", "host": ["{{baseUrl}}"], "path": ["v1", "clinical-records", "{{recordId}}"] } }
        },
        {
          "name": "Recalculate Metrics",
          "event": [ { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('BMI recalculated', () => pm.expect(json.data.bmi).to.be.a('number'));"] } } ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/clinical-records/{{recordId}}/recalculate", "host": ["{{baseUrl}}"], "path": ["v1", "clinical-records", "{{recordId}}", "recalculate"] }, "body": { "mode": "raw", "raw": "{\n  \"weightKg\": 70, \"heightCm\": 170, \"age\": 34, \"gender\": \"male\"\n}" } }
        }
      ]
    },
    {
      "name": "Diet Plans",
      "event": [
        { "listen": "prerequest", "script": { "exec": ["if (!pm.collectionVariables.get('accessToken')) { console.log('Run Auth > Login Nutritionist first'); }"] } }
      ],
      "item": [
        {
          "name": "Create Plan",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.test('Has days', () => pm.expect(json.data.days).to.be.an('array'));", "pm.collectionVariables.set('planId', json.data.id);"] } }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/meal-plans", "host": ["{{baseUrl}}"], "path": ["v1", "meal-plans"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Plan Keto\",\n  \"notes\": \"Low carb\",\n  \"days\": [{ \"dayNumber\": 1, \"meals\": [{ \"name\": \"Desayuno\", \"items\": [{ \"name\": \"Huevos\", \"portion\": \"2 pz\", \"calories\": 140 }] }] }]\n}" } }
        },
        {
          "name": "List Plans",
          "event": [ { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Is array', () => pm.expect(pm.response.json().data).to.be.an('array'));"] } } ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": { "raw": "{{baseUrl}}/v1/meal-plans", "host": ["{{baseUrl}}"], "path": ["v1", "meal-plans"] } }
        },
        {
          "name": "Get Plan",
          "event": [ { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } } ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": { "raw": "{{baseUrl}}/v1/meal-plans/{{planId}}", "host": ["{{baseUrl}}"], "path": ["v1", "meal-plans", "{{planId}}"] } }
        },
        {
          "name": "Assign Plan",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.test('Is active', () => pm.expect(json.data.active).to.be.true);"] } }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/meal-plans/{{planId}}/assign", "host": ["{{baseUrl}}"], "path": ["v1", "meal-plans", "{{planId}}", "assign"] }, "body": { "mode": "raw", "raw": "{\n  \"patientId\": \"{{patientId}}\"\n}" } }
        }
      ]
    },
    {
      "name": "Adherence",
      "item": [
        {
          "name": "Log Meal (Patient)",
          "event": [
            { "listen": "prerequest", "script": { "exec": ["if (!pm.collectionVariables.get('patientToken')) { console.log('Run Auth > Login Patient first'); }"] } },
            { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.collectionVariables.set('mealLogId', json.data.id);"] } }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/adherence/meals", "host": ["{{baseUrl}}"], "path": ["v1", "adherence", "meals"] }, "body": { "mode": "raw", "raw": "{\n  \"mealName\": \"Desayuno\",\n  \"date\": \"2025-06-01T08:00:00Z\",\n  \"consumed\": true\n}" } }
        },
        {
          "name": "Log Hydration (Patient)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.test('Has amountMl', () => pm.expect(json.data.amountMl).to.be.a('number'));"] } }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/adherence/hydration", "host": ["{{baseUrl}}"], "path": ["v1", "adherence", "hydration"] }, "body": { "mode": "raw", "raw": "{\n  \"amountMl\": 500\n}" } }
        },
        {
          "name": "Log Mood (Patient)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Has mood', () => pm.expect(pm.response.json().data.mood).to.be.a('string'));"] } }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/adherence/mood", "host": ["{{baseUrl}}"], "path": ["v1", "adherence", "mood"] }, "body": { "mode": "raw", "raw": "{\n  \"mood\": \"happy\",\n  \"note\": \"Feeling great\"\n}" } }
        },
        {
          "name": "My Summary (Patient)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('Has mealAdherencePercent', () => pm.expect(json.data.mealAdherencePercent).to.be.a('number'));", "pm.test('Has moodDistribution', () => pm.expect(json.data.moodDistribution).to.be.an('object'));"] } }
          ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }], "url": { "raw": "{{baseUrl}}/v1/adherence/my-summary?days=30", "host": ["{{baseUrl}}"], "path": ["v1", "adherence", "my-summary"], "query": [{ "key": "days", "value": "30" }] } }
        },
        {
          "name": "Patient Summary (Nutritionist)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('Has adherence data', () => { pm.expect(json.data.avgDailyWaterMl).to.be.a('number'); });"] } }
          ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": { "raw": "{{baseUrl}}/v1/adherence/summary/{{patientUserId}}", "host": ["{{baseUrl}}"], "path": ["v1", "adherence", "summary", "{{patientUserId}}"] } }
        }
      ]
    },
