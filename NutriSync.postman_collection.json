          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.collectionVariables.set('medicationId', json.data.id);"] } }
          ],
          "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }, { "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/v1/medications", "host": ["{{baseUrl}}"], "path": ["v1", "medications"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Metformina\",\n  \"dosage\": \"500mg\",\n  \"reminderEnabled\": true,\n  \"times\": [\"08:00\", \"20:00\"],\n  \"days\": [\"mon\", \"tue\", \"wed\", \"thu\", \"fri\"],\n  \"intervalHours\": 12\n}" } }
        },
