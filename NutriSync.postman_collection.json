          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }], "url": { "raw": "{{baseUrl}}/v1/medications", "host": ["{{baseUrl}}"], "path": ["v1", "medications"] } }
        },
