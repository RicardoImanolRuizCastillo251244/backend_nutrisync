          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }], "url": { "raw": "{{baseUrl}}/v1/voice-notes", "host": ["{{baseUrl}}"], "path": ["v1", "voice-notes"] } }
