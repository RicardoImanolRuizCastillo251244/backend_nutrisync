    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard (Nutritionist)",
          "event": [
            { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('Has totalPatients', () => pm.expect(json.data.totalPatients).to.be.a('number'));", "pm.test('Has activePlans', () => pm.expect(json.data.activePlans).to.be.a('number'));", "pm.test('Has avgAdherence', () => pm.expect(json.data.avgAdherence).to.be.a('number'));", "pm.test('Has recentActivity', () => pm.expect(json.data.recentActivity).to.be.an('array'));", "pm.test('Has patientsWithLowAdherence', () => pm.expect(json.data.patientsWithLowAdherence).to.be.an('array'));"] } }
          ],
