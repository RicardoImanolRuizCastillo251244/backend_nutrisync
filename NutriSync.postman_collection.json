        },
        {
          "name": "List Takes (Patient)",
          "event": [ { "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Is array', () => pm.expect(pm.response.json().data).to.be.an('array'));"] } } ],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }], "url": { "raw": "{{baseUrl}}/v1/medications/{{medicationId}}/takes", "host": ["{{baseUrl}}"], "path": ["v1", "medications", "{{medicationId}}", "takes"] } }
        },
        {
          "name": "Nutritionist Access DENIED (403)",
          "event": [ { "listen": "test", "script": { "exec": ["pm.test('Status 403 blocked', () => pm.response.to.have.status(403));"] } } ],
