generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  nutritionist
  patient
}

enum Gender {
  male
  female
  other
}

model User {
  id            String            @id @default(uuid())
  email         String            @unique
  passwordHash  String
  role          Role
  name          String
  nutritionistId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  patientProfile Patient?
  sessions      RefreshSession[]
  progressLogs  ProgressLog[]
  medications   Medication[]
  hydrationLogs HydrationLog[]
  moodLogs      MoodLog[]
  mealLogs      MealLog[]
  voiceNotes    VoiceNote[]
}

model Patient {
  id                 String      @id @default(uuid())
  userId             String      @unique
  nutritionistUserId String?
  status             String      @default("pending")
  phone              String?
  birthDate          DateTime?
  gender             Gender?
  deletedAt          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinicalRecords    ClinicalRecord[]
  dietAssignments    PatientPlanAssignment[]
}

model RefreshSession {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  replacedBy  String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClinicalRecord {
  id                  String   @id @default(uuid())
  patientId           String
  date                DateTime @default(now())

  // Datos personales
  name                String?  @db.VarChar(255)
  sex                 String?  @db.VarChar(50)
  age                 Int?
  occupation          String?  @db.VarChar(255)
  bloodType           String?  @db.VarChar(10)
  consultationReason  String?  @db.VarChar(500)
  phone               String?  @db.VarChar(50)
  weightKg            Float?
  heightCm            Float?
  maritalStatus       String?  @db.VarChar(100)
  allergies           String?  @db.VarChar(500)
  feedingDifficulty   Boolean  @default(false)
  address             String?  @db.VarChar(255)

  // Antecedentes heredofamiliares
  familyObesity       Boolean  @default(false)
  familyCancer        Boolean  @default(false)
  familyHypertension  Boolean  @default(false)
  familyHIV           Boolean  @default(false)
  familyDiabetesType1 Boolean  @default(false)
  familyDiabetesType2 Boolean  @default(false)
  familyOther         String?  @db.VarChar(255)

  // Antecedentes patológicos personales
  personalDiarrhea    Boolean  @default(false)
  personalColitis     Boolean  @default(false)
  personalReflux      Boolean  @default(false)
  personalConstipation Boolean @default(false)
  personalNausea      Boolean  @default(false)
  personalGastritis   Boolean  @default(false)
  personalVomiting    Boolean  @default(false)
  personalOther       String?  @db.VarChar(255)

  // Laboratorios
  labGlucose          Float?
  labCholesterol      Float?
  labTriglycerides    Float?

  // Exploración física
  physicalHair        String?  @db.VarChar(100)
  physicalMouth       String?  @db.VarChar(100)
  physicalTeeth       String?  @db.VarChar(100)
  physicalEyes        String?  @db.VarChar(100)
  physicalGums        String?  @db.VarChar(100)
  physicalNails       String?  @db.VarChar(100)

  // Métricas calculadas
  bmi                 Float?
  bmiClassification   String?  @db.VarChar(100)
  bodyFatPercentage   Float?
  visceralFat         Float?
  muscleMass          Float?
  biologicalAge       Int?
  restingMetabolism   Int?
  riskLevel           String?  @db.VarChar(100)

  // Metadata
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model DietPlan {
  id                String                  @id @default(uuid())
  nutritionistUserId String
  name              String
  notes             String?
  isActive          Boolean                 @default(false)
  deletedAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  days              DietDay[]
  assignments       PatientPlanAssignment[]
}

model DietDay {
  id         String   @id @default(uuid())
  planId     String
  dayNumber  Int
  createdAt  DateTime @default(now())

  plan       DietPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  meals      Meal[]

  @@unique([planId, dayNumber])
}

model Meal {
  id         String         @id @default(uuid())
  dayId      String
  name       String
  note       String?
  createdAt  DateTime       @default(now())

  day        DietDay        @relation(fields: [dayId], references: [id], onDelete: Cascade)
  items      MealFoodItem[]
}

model MealFoodItem {
  id               String    @id @default(uuid())
  mealId           String
  name             String
  portion          String?
  calories         Float?
  protein          Float?
  carbs            Float?
  fat              Float?
  edamamRecipeUrl  String?
  imageUrl         String?
  healthLabels     String[]
  dietLabels       String[]
  ingredients      Json?

  meal             Meal      @relation(fields: [mealId], references: [id], onDelete: Cascade)
}

model PatientPlanAssignment {
  id                String    @id @default(uuid())
  patientId         String
  planId            String
  nutritionistUserId String
  active            Boolean   @default(true)
  assignedAt        DateTime  @default(now())
  endedAt           DateTime?

  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  plan              DietPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model MealLog {
  id           String   @id @default(uuid())
  patientUserId String
  planId       String?
  mealName     String
  note         String?
  date         DateTime
  consumed     Boolean  @default(false)
  consumedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientUser  User     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  voiceNotes   VoiceNote[]
}

model VoiceNote {
  id           String   @id @default(uuid())
  patientUserId String
  mealLogId    String
  storageKey   String
  publicUrl    String
  durationSec  Int?
  createdAt    DateTime @default(now())

  patientUser  User     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  mealLog      MealLog  @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
}

model HydrationLog {
  id            String   @id @default(uuid())
  patientUserId String
  amountMl      Int
  loggedAt      DateTime @default(now())

  patientUser   User     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id            String   @id @default(uuid())
  patientUserId String
  mood          String
  note          String?
  loggedAt      DateTime @default(now())

  patientUser   User     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
}

model Medication {
  id              String   @id @default(uuid())
  patientUserId   String
  name            String
  dosage          String
  reminderEnabled Boolean  @default(false)
  times           String[]
  days            String[]
  intervalHours   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patientUser     User     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  takes           MedicationTake[]
}

model MedicationTake {
  id            String   @id @default(uuid())
  medicationId  String
  takenAt       DateTime @default(now())

  medication    Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model ProgressLog {
  id            String   @id @default(uuid())
  patientUserId String
  weightKg      Float?
  bmi           Float?
  createdAt     DateTime @default(now())

  patientUser   User     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
}